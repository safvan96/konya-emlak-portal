generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum ListingType {
  SALE
  RENT
}

enum ListingStatus {
  ACTIVE
  PASSIVE
  SOLD
  RENTED
}

model City {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique
  sahibindenCityId String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  listings        Listing[]

  @@map("cities")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String
  name          String
  surname       String
  role          Role         @default(CUSTOMER)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  assignments   Assignment[]
  favorites     Favorite[]
  logs          UserLog[]
  notes         ListingNote[]
  preferences   CustomerPreference?

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  listings  Listing[]

  @@map("categories")
}

model Listing {
  id              String        @id @default(cuid())
  sahibindenId    String        @unique
  title           String
  description     String
  price           Float?
  currency        String        @default("TL")
  listingType     ListingType   @default(SALE)
  location        String?
  district        String?
  neighborhood    String?
  roomCount       String?
  squareMeters    Int?
  buildingAge     String?
  floor           String?
  imageUrls       String[]
  sourceUrl       String
  sahibindenUrl   String?
  sellerName      String?
  sellerPhone     String?
  isFromOwner     Boolean       @default(true)
  rejectionReason String?
  status          ListingStatus @default(ACTIVE)
  cityId          String
  city            City          @relation(fields: [cityId], references: [id])
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id])
  scrapedAt       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  assignments     Assignment[]
  favorites       Favorite[]
  notes           ListingNote[]
  priceHistory    PriceHistory[]

  @@index([cityId])
  @@index([categoryId])
  @@index([isFromOwner])
  @@index([status])
  @@index([listingType])
  @@index([isFromOwner, status])
  @@index([cityId, status, isFromOwner])
  @@index([createdAt])
  @@map("listings")
}

model Assignment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  assignedBy String
  assignedAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("assignments")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@map("favorites")
}

model UserLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("user_logs")
}

model ScraperRun {
  id            String   @id @default(cuid())
  cityId        String
  totalFound    Int      @default(0)
  accepted      Int      @default(0)
  rejected      Int      @default(0)
  duplicates    Int      @default(0)
  errors        Int      @default(0)
  duration      Int?
  status        String   @default("running")
  errorMessage  String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?

  @@map("scraper_runs")
}

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  oldPrice  Float?
  newPrice  Float?
  changedAt DateTime @default(now())

  @@index([listingId])
  @@map("price_history")
}

model CustomerPreference {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityIds      String[]
  categoryIds  String[]
  listingType  String?  // SALE, RENT, null=both
  priceMin     Float?
  priceMax     Float?
  autoAssign   Boolean @default(false)

  @@map("customer_preferences")
}

model ListingNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, listingId])
  @@map("listing_notes")
}

model BlacklistKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  createdAt DateTime @default(now())

  @@map("blacklist_keywords")
}

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/konya_emlak?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# Scraper
SCRAPER_ENABLED=true
SCRAPER_DELAY_MIN=2000
SCRAPER_DELAY_MAX=5000

# Sahibinden Login (VPS'den erisim icin gerekli olabilir)
SAHIBINDEN_EMAIL=
SAHIBINDEN_PASSWORD=

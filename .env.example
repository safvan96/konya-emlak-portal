# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/konya_emlak?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# Scraper
SCRAPER_ENABLED=true
SCRAPER_DELAY_MIN=2000
SCRAPER_DELAY_MAX=5000

# Sahibinden Login (VPS'den erisim icin gerekli olabilir)
SAHIBINDEN_EMAIL=
SAHIBINDEN_PASSWORD=

# Scraper Erişim (VPS IP engeli için EN AZ BİRİ gerekli)
# Yontem 1: ScraperAPI (scraperapi.com - 1000 istek ücretsiz)
# SCRAPER_API_KEY=your_scraper_api_key
# Yontem 2: Zenrows (zenrows.com)
# ZENROWS_API_KEY=your_zenrows_api_key
# Yontem 3: Residential Proxy
# PROXY_URL=http://user:pass@host:port
